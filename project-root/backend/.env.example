# DokPotok IRIS - Environment Variables Example
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИТЕ ЗНАЧЕНИЯМИ

# === ОБЯЗАТЕЛЬНО ДЛЯ PRODUCTION ===

# SECRET_KEY - должен быть уникальным, минимум 32 символа
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# НЕ используйте дефолтное значение в production!
SECRET_KEY=your-super-secret-key-change-in-production-please-min-32-chars

# DATABASE_URL
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/iris

# === Опционально ===

# API Version
API_V1_STR=/api/v1

# Access token TTL in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Refresh token TTL in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins - перечислите ТОЛЬКО доверенные домены
# НЕ используйте localhost в production!
# BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
BACKEND_CORS_ORIGINS=[]

# Logging level
IRIS_LOG_LEVEL=INFO

# Storage root
IRIS_STORAGE_ROOT=/app/storage

# === Frontend ===
# VITE_API_URL=https://yourdomain.com/api
