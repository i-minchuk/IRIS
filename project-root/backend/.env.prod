# ⚠️ PRODUCTION SETTINGS - Do NOT commit to version control!
# Copy to .env and fill in secure values

# Database
DATABASE_URL=postgresql+asyncpg://iris:your_secure_password_here@localhost:5432/iris

# Security
SECRET_KEY=your_jwt_secret_64_chars_random_string_generated_with_python_script

# CORS
BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Logging
IRIS_LOG_LEVEL=INFO

# Redis (optional)
REDIS_URL=redis://localhost:6379